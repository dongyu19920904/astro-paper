---
/**
 * 项目导航页面
 * ============
 * 这个页面展示你所有的项目卡片
 * 项目数据来自 src/data/navProjects.ts 的 PROJECTS 数组
 * 要添加新项目，只需编辑那个文件即可
 */
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { PROJECTS } from "@/data/navProjects";
---

<Layout>
  <Header />
  <main id="main-content" class="app-layout">
    <section class="border-b border-border pt-8 pb-6">
      <h1 class="text-3xl font-bold sm:text-4xl">我的项目</h1>
      <p class="text-base-content/70 mt-4">
        白天搞钱，晚上搞研究。这些是我正在运营的项目，点击卡片直接跳转。
      </p>
    </section>

    <section class="pt-8 pb-6">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        {
          PROJECTS.map(project => (
            <a
              href={project.url}
              class="group bg-base-100 flex flex-col gap-2 rounded-xl border border-border p-5 transition-all hover:border-accent hover:shadow-lg"
              target={project.url.startsWith("http") ? "_blank" : "_self"}
              rel={
                project.url.startsWith("http")
                  ? "noopener noreferrer"
                  : undefined
              }
            >
              <div class="flex items-center gap-3">
                <span class="text-3xl">{project.icon || "📦"}</span>
                <span class="text-lg font-semibold group-hover:text-accent">
                  {project.title}
                </span>
              </div>
              <p class="text-base-content/70 flex-1 text-sm">{project.desc}</p>
              {project.technologies && (
                <div class="flex flex-wrap gap-1.5" aria-label="技术标签">
                  {project.technologies.map(technology => (
                    <span class="text-base-content/60 rounded-full border border-border px-2 py-0.5 text-[0.7rem]">
                      {technology}
                    </span>
                  ))}
                </div>
              )}
              {(project.status || project.updatedAt) && (
                <p class="text-base-content/55 text-xs">
                  {project.status}
                  {project.status && project.updatedAt ? " · " : ""}
                  {project.updatedAt ? `更新于 ${project.updatedAt}` : ""}
                </p>
              )}
              <div class="mt-2 flex items-center justify-between">
                <span class="inline-block rounded-full bg-accent/10 px-2 py-0.5 text-xs text-accent">
                  {project.tag}
                </span>
                <span class="text-base-content/50 text-xs group-hover:text-accent">
                  {project.url.startsWith("http") ? "外部链接 ↗" : "站内 →"}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="py-8 text-center">
      <p class="text-base-content/60">
        2029 年前，这个列表会越来越长。敬请期待。
      </p>
    </section>
  </main>
  <Footer />
</Layout>
