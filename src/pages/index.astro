---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { NAV_LINKS } from "@/data/navProjects";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const dispatchPosts = sortedPosts.slice(0, 3);
const signalStats = [
  {
    label: "项目入口",
    value: String(NAV_LINKS.length).padStart(2, "0"),
    note: "AI 店铺 / 日报 / 导航 / 博客",
  },
  {
    label: "博客档案",
    value: String(sortedPosts.length).padStart(2, "0"),
    note: "持续更新的 AI 与 BioAI 观察",
  },
  {
    label: "精选内容",
    value: String(featuredPosts.length).padStart(2, "0"),
    note: "长期命题与重点追踪",
  },
];
---

<Layout
  title="yuyu | AI 日报、BioAI 与个人博客"
  description="yuyu 的个人主页，聚合 AI 日报、BioAI、个人博客与项目入口，持续更新 AI 工具、商机与生命科学观察。"
>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="launchpad" class="launchpad">
      <div class="launchpad-shell">
        <div class="launchpad-masthead launchpad-panel">
          <div class="launchpad-heading">
            <span class="launchpad-eyebrow">FUTURE EDITORIAL DESK</span>
            <div class="launchpad-title-row">
              <h1 class="launchpad-name">yuyu</h1>
              <a
                target="_blank"
                href="/rss.xml"
                class="launchpad-rss"
                aria-label="rss feed"
                title="RSS Feed"
              >
                <IconRss
                  width={20}
                  height={20}
                  class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
                />
                <span class="sr-only">RSS Feed</span>
              </a>
            </div>
            <p class="launchpad-tagline">
              把 AI 日报、BioAI、个人实验与长期主题，整理成一个更像内容产品的总控台。
            </p>
            <p class="launchpad-sub">
              这里不是单纯的博客首页，而是一张正在运行的编辑台地图。你可以从这里直接进入 AI 情报流、BioAI 研究流和我的长期写作档案。
            </p>
            <div class="launchpad-chips">
              <span class="launchpad-chip">AI Daily Desk</span>
              <span class="launchpad-chip">BioAI Research</span>
              <span class="launchpad-chip">Personal Lab Notes</span>
            </div>
            <div class="launchpad-actions">
              <LinkButton href="/posts/" class="launchpad-primary">
                浏览博客档案
                <IconArrowRight class="inline-block rtl:-rotate-180" />
              </LinkButton>
              <LinkButton
                href="https://news.aivora.cn"
                target="_blank"
                rel="noopener noreferrer"
                class="launchpad-secondary"
              >
                打开 AI 日报
              </LinkButton>
            </div>
          </div>
          <aside class="dispatch-board" aria-label="站点动态概览">
            <div class="dispatch-board__header">
              <div>
                <p class="dispatch-board__eyebrow">Live Desk</p>
                <h2 class="dispatch-board__title">今日总览</h2>
              </div>
              <span class="dispatch-board__badge">Daily Refresh</span>
            </div>
            <div class="dispatch-board__stats">
              {
                signalStats.map(item => (
                  <article class="dispatch-stat">
                    <span class="dispatch-stat__value">{item.value}</span>
                    <div class="dispatch-stat__copy">
                      <h3>{item.label}</h3>
                      <p>{item.note}</p>
                    </div>
                  </article>
                ))
              }
            </div>
            <div class="dispatch-board__feed">
              <div class="dispatch-board__feed-title">最新调度</div>
              <ul class="dispatch-feed">
                {
                  dispatchPosts.map(post => (
                    <li class="dispatch-feed__item">
                      <a href={getPath(post.id, post.filePath)} class="dispatch-feed__link">
                        <span class="dispatch-feed__label">
                          {post.data.featured ? "Cover" : "Dispatch"}
                        </span>
                        <span class="dispatch-feed__headline">{post.data.title}</span>
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </aside>
        </div>

        <div class="signal-strip launchpad-panel" aria-label="站点路线图">
          <div class="signal-strip__intro">
            <span class="signal-strip__eyebrow">Route Map</span>
            <p class="signal-strip__text">
              三条主线并行运行：即时 AI 信息、BioAI 长期观察、以及个人项目化写作。
            </p>
          </div>
          <div class="signal-strip__grid">
            <a class="signal-tile" href="https://news.aivora.cn" target="_blank" rel="noopener noreferrer">
              <span class="signal-tile__label">情报流</span>
              <strong class="signal-tile__title">AI 日报</strong>
              <span class="signal-tile__meta">热点、商机、账号机会</span>
            </a>
            <a class="signal-tile" href="https://news.aibioo.cn" target="_blank" rel="noopener noreferrer">
              <span class="signal-tile__label">研究流</span>
              <strong class="signal-tile__title">BioAI 日报</strong>
              <span class="signal-tile__meta">生命科学、长寿、AI 生物研究</span>
            </a>
            <a class="signal-tile" href="/posts/">
              <span class="signal-tile__label">档案流</span>
              <strong class="signal-tile__title">个人博客</strong>
              <span class="signal-tile__meta">把日报延展成更完整的长期内容</span>
            </a>
          </div>
        </div>

        <div class="launchpad-grid launchpad-panel grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
          {
            NAV_LINKS.map((link, index) => (
              <a
                href={link.url}
                class="project-card"
                style={`--delay: ${index * 90}ms`}
                target={link.url.startsWith("http") ? "_blank" : "_self"}
                rel={
                  link.url.startsWith("http") ? "noopener noreferrer" : undefined
                }
              >
                <div class="flex items-center gap-3">
                  <span class="project-icon">{link.icon}</span>
                  <span class="project-title">{link.title}</span>
                </div>
                <p class="project-desc">{link.desc}</p>
                <div class="project-footer">
                  <span class="project-tag">{link.tag}</span>
                  <span class="project-arrow">→</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section id="about" class="operator-section border-b border-border">
      <div class="section-heading">
        <h2 class="section-heading__title">关于这个站</h2>
        <span class="section-heading__label">Operator Notes</span>
      </div>
      <div class="operator-room">
        <div class="operator-room__copy">
          <p class="operator-room__lead">
            我在做的事情很简单：一边做 AI 工具和内容，一边长期追踪 AI 与生命科学交叉的机会。
          </p>
          <p>
            这个主页就是我的内容总控台。它把日报、商机、博客和项目入口放在一起，让内容不只是“写完就结束”，而是继续演化成更有用的产品和观察。
          </p>
          <p>
            如果你关心 AI 工具、内容生意、BioAI、长寿研究，或者只是想看一个人如何把碎片信息慢慢做成长期资产，这里就是入口。
          </p>
          {
            SOCIALS.length > 0 && (
              <div class="operator-room__socials">
                <div class="operator-room__socials-label">找我聊聊</div>
                <Socials />
              </div>
            )
          }
        </div>
        <div class="about-panel">
          <div class="about-row">
            <span class="about-label">正在推进</span>
            <span class="about-value">AI 日报 / BioAI 日报</span>
          </div>
          <div class="about-row">
            <span class="about-label">主航向</span>
            <span class="about-value">AI 长寿赛道</span>
          </div>
          <div class="about-row">
            <span class="about-label">目标</span>
            <span class="about-value">把长期研究做成真正有用的东西</span>
          </div>
        </div>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={["story-section", { "border-b border-border": recentPosts.length > 0 }]}
        >
          <div class="section-heading">
            <h2 class="section-heading__title">精选主稿</h2>
            <span class="section-heading__label">Cover Stories</span>
          </div>
          <ul class="story-grid">
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="story-section">
          <div class="section-heading">
            <h2 class="section-heading__title">最新派送</h2>
            <span class="section-heading__label">Archive Feed</span>
          </div>
          <ul class="story-grid">
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="archive-cta">
      <LinkButton href="/posts/" class="launchpad-primary">
        查看全部文章
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
