---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, tags = [], featured, ...props } = data;
const firstTag = tags[0];
---

<li class="story-card">
  <article class="story-card__shell">
    <div class="story-card__meta">
      <span class="story-card__kicker">{featured ? "Cover Story" : "Field Note"}</span>
      <Datetime {...props} class="story-card__datetime" />
    </div>
    <a
      href={getPath(id, filePath)}
      class:list={[
        "story-card__title-link",
        "focus-visible:no-underline focus-visible:underline-offset-0",
      ]}
    >
      <Heading
        class="story-card__title"
        style={{ viewTransitionName: slugifyStr(title) }}
      >
        {title}
      </Heading>
    </a>
    <p class="story-card__description">{description}</p>
    <div class="story-card__footer">
      {firstTag ? <span class="story-card__pill">{firstTag}</span> : <span class="story-card__pill">博客</span>}
      <span class="story-card__readmore">继续阅读 →</span>
    </div>
  </article>
</li>
